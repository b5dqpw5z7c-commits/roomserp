{
  "name": "rooms-erp-cloud-mvp",
  "version": "1.2.0",
  "description": "ROOM'S Interior Cloud ERP MVP v3 - frontend/backend aligned and hardened",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "db:reset": "node scripts/reset-db.js",
    "test": "node --test tests/*.test.js",
    "check": "find src scripts -name \"*.js\" -print0 | xargs -0 -n1 node --check"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {}
}
